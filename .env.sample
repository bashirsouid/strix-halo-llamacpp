# Strix Halo Llama.cpp Environment Configuration
# Copy this file to .env and fill in your values

# API Key for server authentication (required for production use)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-api-key-here

# Optional: LLaMA.cpp version pin (default: HEAD)
# LLAMACPP_REF=b8656

# Optional: LLaMA.cpp repository (default: ggml-org/llama.cpp)
# LLAMACPP_REPO=ggml-org/llama.cpp
