+    assert server._resolve_aider_threads(cfg, None) == (3, "models.py parallel_slots")
+    assert server._resolve_aider_threads(cfg, 2) == (2, "--threads")
+    assert server._resolve_aider_context_window(cfg, 3) == 12288
