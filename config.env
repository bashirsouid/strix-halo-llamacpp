# =============================================================================
# Strix Halo — llama.cpp (Vulkan RADV) configuration
# =============================================================================

# Docker image tag for kyuz0's toolbox
LLAMA_IMAGE_TAG=vulkan-radv
###LLAMA_IMAGE_TAG=vulkan-amdvlk
###LLAMA_IMAGE_TAG=rocm-6.4.4-rocwmma

# ── Paths ─────────────────────────────────────────────────────────────────────
MODELS_DIR=/mnt/data/models
HOST_LLAMA_CACHE=/mnt/data/llama.cpp-cache
EXTRA_MODEL_SEARCH_DIRS=

# ── Server defaults ───────────────────────────────────────────────────────────
SERVER_PORT=8000

# ── Default model loader ──────────────────────────────────────────────────────
# This is the ONLY place you pick the default model.
# All per-model details live in the corresponding load_*.sh.
DEFAULT_LOADER=load_mistral-small-4_q4.sh

# ── Global llama-server tuning defaults (loaders can override) ───────────────
LLAMA_TEMP=0.2
LLAMA_TOP_P=0.95

# Runtime overrides (set by load_*.sh scripts; leave blank here)
MODEL_FLAG=
MODEL_VALUE=